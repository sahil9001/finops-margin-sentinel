# =========================================================================
# FinOps Margin Sentinel - Environment Variables Example
# Duplicate this file as '.env' in the same folder and fill in your keys.
# =========================================================================

# Anthropic API Key (Claude Sonnet agent reasoning brain)
# Get from: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Stripe Credentials (to seed and check customer subscriptions)
# Get from: https://dashboard.stripe.com/test/apikeys
STRIPE_SECRET_KEY=sk_test_your_secret_key_here

# Langfuse Credentials (to log and query LLM token metrics)
# Get from: Settings -> API Keys in your Langfuse project dashboard
LANGFUSE_PUBLIC_KEY=pk-lf-your_public_key_here
LANGFUSE_SECRET_KEY=sk-lf-your_secret_key_here
LANGFUSE_HOST=https://api.langfuse.com

# PostHog Credentials (to track customer product usage events)
# Get from: Project Settings -> API Keys in PostHog
POSTHOG_API_KEY=phc_your_project_api_key_here
POSTHOG_HOST=https://us.i.posthog.com
